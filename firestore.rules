rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (Pillar 1)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable Hardened helper functions (Phase 3 & 4)
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Hardened Validate Helpers (Pillar 2, Strict Keys & Limit size guards)
    function isValidUserProfile(data) {
      return data.keys().hasAll(['username', 'name', 'avatar', 'bio', 'followers', 'following', 'verified'])
        && data.username is string && data.username.size() <= 32
        && data.name is string && data.name.size() <= 50
        && data.avatar is string && data.avatar.size() <= 500
        && data.bio is string && data.bio.size() <= 300
        && data.followers is int
        && data.following is int
        && data.verified is bool;
    }

    function isValidMeme(data) {
      return data.keys().hasAll(['id', 'type', 'src', 'caption', 'likes', 'commentsCount', 'creator', 'audioTrack', 'tags'])
        && data.id is string && data.id.size() <= 64
        && data.type is string && (data.type == 'image' || data.type == 'video')
        && data.src is string && data.src.size() <= 500
        && data.caption is string && data.caption.size() <= 1000
        && data.likes is int
        && data.commentsCount is int
        && data.creator is map
        && data.audioTrack is string && data.audioTrack.size() <= 200
        && data.tags is list && data.tags.size() <= 10;
    }

    function isValidComment(data) {
      return data.keys().hasAll(['username', 'avatar', 'text', 'timestamp'])
        && data.username is string && data.username.size() <= 50
        && data.avatar is string && data.avatar.size() <= 500
        && data.text is string && data.text.size() <= 1000
        && data.timestamp is string && data.timestamp.size() <= 100;
    }

    function isValidLike(data) {
      return data.keys().hasAll(['userId']) && data.userId is string && data.userId.size() <= 128;
    }

    function isValidSave(data) {
      return data.keys().hasAll(['userId']) && data.userId is string && data.userId.size() <= 128;
    }

    function isValidFollow(data) {
      return data.keys().hasAll(['followerId', 'creatorUsername'])
        && data.followerId is string && data.followerId.size() <= 128
        && data.creatorUsername is string && data.creatorUsername.size() <= 50;
    }

    // Collection Route rules matches
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUserProfile(incoming());
      allow update: if isOwner(userId) && isValidUserProfile(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'bio', 'followers', 'following', 'verified']);
      allow delete: if isOwner(userId);

      match /saves/{saveId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidSave(incoming());
        allow delete: if isOwner(userId);
      }

      match /following/{followId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFollow(incoming());
        allow delete: if isOwner(userId);
      }
    }

    match /memes/{memeId} {
      // Query Enforcer (Pillar 8)
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isSignedIn() && isValidMeme(incoming());
      allow update: if isSignedIn() && isValidMeme(incoming())
        && (incoming().diff(existing()).affectedKeys().hasOnly(['likes', 'commentsCount']));
      allow delete: if isSignedIn();

      match /comments/{commentId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isValidComment(incoming());
        allow delete: if isSignedIn();
      }

      match /likes/{likeId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && isOwner(likeId) && isValidLike(incoming());
        allow delete: if isSignedIn() && isOwner(likeId);
      }
    }
  }
}
